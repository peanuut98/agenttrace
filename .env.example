NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" to bypass Supabase auth and persist projects/runs to
# localStorage instead. Useful while auth is still in flux. MUST be left as
# "false" (or unset) before shipping to production.
NEXT_PUBLIC_DEV_MODE=true

# AI Provider Configuration (Server-only — never exposed to browser)
# AgentTrace uses a pluggable AI provider for generating audit reports.
#
# AI_PROVIDER options:
# - "z_ai" (recommended): Z.ai GLM-5.1 — primary provider for AI Audit Reports
# - "claude_compatible": third-party Claude-compatible API provider
# - "mock": deterministic fallback, no API key needed
#
# When AI_PROVIDER is not set or the selected provider's API key is missing,
# AgentTrace falls back to the mock provider (with a fallback_reason set on
# the returned report).
AI_PROVIDER=z_ai

# Z.ai GLM-5.1 provider (primary, used when AI_PROVIDER=z_ai)
ZAI_API_KEY=
ZAI_MODEL=glm-5.1
ZAI_API_BASE=https://api.z.ai/api/paas/v4

# Optional Claude-compatible API provider (used when AI_PROVIDER=claude_compatible)
# Many third-party Claude API providers use OpenAI-compatible format.
CLAUDE_COMPATIBLE_API_KEY=
CLAUDE_COMPATIBLE_API_BASE=
CLAUDE_COMPATIBLE_MODEL=

# Blockchain Explorer API Keys (Transaction-to-Trace feature)
# Optional. If not set, transaction imports will use mock fallback data.
# Get API keys from:
# - Base Sepolia: https://basescan.org/apis
# - Ethereum Sepolia: https://etherscan.io/apis
NEXT_PUBLIC_BASESCAN_API_KEY=
NEXT_PUBLIC_ETHERSCAN_API_KEY=
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# On-chain Proof Registry (Base Sepolia testnet)
# Public contract address — safe to ship as NEXT_PUBLIC_*. Never put private
# keys, mnemonics, or paid RPC keys into NEXT_PUBLIC_* variables.
# Set this after deploying contracts/AgentTraceProofRegistry.sol via Remix.
# See docs/CONTRACT_DEPLOYMENT.md for the deployment walkthrough.
NEXT_PUBLIC_PROOF_REGISTRY_ADDRESS=
