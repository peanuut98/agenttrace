# AgentTrace — Environment variables example
#
# Copy this file to `.env.local` (which is git-ignored) and fill in your own
# Supabase project values. Both keys are taken from the Supabase dashboard:
#   Project Settings → API → "Project URL" and "anon / public" key.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
