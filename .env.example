NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" to bypass Supabase auth and persist projects/runs to
# localStorage instead. Useful while auth is still in flux. MUST be left as
# "false" (or unset) before shipping to production.
NEXT_PUBLIC_DEV_MODE=false

# AI Summary (Day 4). Server-only — never exposed to the browser. If left
# blank, AgentTrace falls back to a deterministic mock summary built from the
# receipt JSON, so the UI keeps working without any AI provider configured.
# Defaults to claude-haiku-4-5-20251001 when AI_MODEL is unset.
AI_API_KEY=
AI_MODEL=
